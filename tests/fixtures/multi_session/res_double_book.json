      "resource_type": "CPU_SLOT",
      "quantity": 4,
      "tick": 1
    },
    {
      "reservation_id": "r2",
      "session_id": "s2",
      "resource_type": "CPU_SLOT",
      "quantity": 3,
      "tick": 2
    }
  ],
  "expected_result": "conflict",
  "expected_conflict": "resource_double_booking",
  "conflict_on_grant_index": 1
}
